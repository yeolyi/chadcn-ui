---
import { MonitorIcon, SmartphoneIcon } from "lucide-react"

import { ButtonMain } from "@/components/demos/button/ButtonMain"
import { CursorOverlay } from "@/components/docs/CursorOverlay"
import { HeartButton } from "@/components/docs/HeartButton"
import { Badge } from "@/components/ui/badge"
import Docs from "@/layouts/Docs.astro"
import { getButtonVariant, listButtonSlugs } from "@/lib/button-components"
import { fetchLikeCounts } from "@/lib/likes"

export const prerender = false

const sort: "popular" | "alpha" =
  Astro.url.searchParams.get("sort") === "alpha" ? "alpha" : "popular"

const counts = await fetchLikeCounts().catch(() => ({}))

const variants = listButtonSlugs()
  .map((slug) => ({
    slug,
    info: getButtonVariant(slug, "ko"),
    count: counts[slug] ?? 0,
  }))
  .sort((a, b) =>
    sort === "alpha"
      ? a.slug.localeCompare(b.slug)
      : b.count - a.count || a.slug.localeCompare(b.slug),
  )

Astro.response.headers.set(
  "cache-control",
  "public, s-maxage=60, stale-while-revalidate=300",
)
---

<Docs title="Button" description="chadcn의 모든 Button 변형">
  <div class="mx-auto flex w-full max-w-[60rem] min-w-0 flex-1 flex-col gap-8 px-4 py-6 lg:py-8">
    <div class="flex items-center justify-between gap-3">
      <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Button</h1>
      <div
        role="group"
        aria-label="정렬"
        data-sort-toggle
        class="inline-flex h-8 items-center rounded-md border bg-background p-0.5 text-sm"
      >
        <button
          type="button"
          data-sort="popular"
          aria-pressed={sort === "popular"}
          class="rounded-[5px] px-3 h-7 font-medium text-muted-foreground transition-colors hover:text-foreground aria-pressed:bg-accent aria-pressed:text-accent-foreground"
        >
          인기순
        </button>
        <button
          type="button"
          data-sort="alpha"
          aria-pressed={sort === "alpha"}
          class="rounded-[5px] px-3 h-7 font-medium text-muted-foreground transition-colors hover:text-foreground aria-pressed:bg-accent aria-pressed:text-accent-foreground"
        >
          이름순
        </button>
      </div>
    </div>

    <div data-variant-grid class="grid grid-cols-1 gap-4 lg:grid-cols-2">
      {
        variants.map(({ slug, info, count }) => {
          if (!info) return null
          return (
            <article
              data-slug={slug}
              data-like-count={count}
              style={`view-transition-name: vt-${slug}`}
              class="group relative flex flex-col gap-4 rounded-xl border p-5 transition-colors hover:border-foreground/20"
            >
              <div class="absolute right-4 top-4 z-10">
                <HeartButton slug={slug} initialCount={count} client:visible />
              </div>

              <a
                href={`/docs/components/button/${slug}`}
                class="flex flex-col gap-3 pr-16"
              >
                <div class="flex flex-wrap items-center gap-2">
                  <h2 class="text-lg font-semibold tracking-tight group-hover:underline">
                    {slug}
                  </h2>
                  {info.support === "desktop" && (
                    <Badge variant="outline">
                      <MonitorIcon />
                      Desktop only
                    </Badge>
                  )}
                  {info.support === "mobile" && (
                    <Badge variant="outline">
                      <SmartphoneIcon />
                      Mobile only
                    </Badge>
                  )}
                </div>
                <p class="text-sm leading-6 text-muted-foreground">{info.tagline}</p>
              </a>

              <div class="relative mt-auto flex min-h-[88px] items-center justify-center rounded-lg border bg-muted/30 p-6">
                <ButtonMain slug={slug} client:visible />
              </div>
            </article>
          )
        })
      }
    </div>
  </div>
  <CursorOverlay channel="cursors:button" client:idle />
</Docs>

<script>
  const grid = document.querySelector<HTMLElement>("[data-variant-grid]")
  const toggle = document.querySelector<HTMLElement>("[data-sort-toggle]")
  if (grid && toggle) {
    // Seed counts from SSR data attrs so reorders work without an extra fetch.
    const counts: Record<string, number> = {}
    for (const card of Array.from(grid.children) as HTMLElement[]) {
      counts[card.dataset.slug ?? ""] = Number(card.dataset.likeCount ?? 0)
    }

    const sortBy = (mode: string) => {
      const cards = Array.from(grid.children) as HTMLElement[]
      cards.sort((a, b) => {
        const sa = a.dataset.slug ?? ""
        const sb = b.dataset.slug ?? ""
        if (mode === "alpha") return sa.localeCompare(sb)
        return (counts[sb] ?? 0) - (counts[sa] ?? 0) || sa.localeCompare(sb)
      })
      const apply = () => {
        for (const c of cards) grid.appendChild(c)
      }
      const start = (document as any).startViewTransition?.bind(document)
      if (start) start(apply)
      else apply()
    }

    const setPressed = (mode: string) => {
      for (const b of toggle.querySelectorAll<HTMLButtonElement>("[data-sort]")) {
        b.setAttribute("aria-pressed", String(b.dataset.sort === mode))
      }
    }

    toggle.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-sort]")
      if (!btn) return
      const mode = btn.dataset.sort ?? "popular"
      setPressed(mode)
      const url = new URL(window.location.href)
      if (mode === "alpha") url.searchParams.set("sort", "alpha")
      else url.searchParams.delete("sort")
      history.pushState(null, "", url.toString())
      sortBy(mode)
    })

    window.addEventListener("popstate", () => {
      const mode =
        new URL(window.location.href).searchParams.get("sort") === "alpha"
          ? "alpha"
          : "popular"
      setPressed(mode)
      sortBy(mode)
    })

    window.addEventListener("chadcn:like", (e) => {
      const { slug, count } = (e as CustomEvent).detail as {
        slug: string
        count: number
      }
      counts[slug] = count
      const popular = toggle.querySelector<HTMLButtonElement>('[data-sort="popular"]')
      if (popular?.getAttribute("aria-pressed") === "true") sortBy("popular")
    })
  }
</script>
