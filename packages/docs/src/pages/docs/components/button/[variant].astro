---
import { getRelativeLocaleUrl } from "astro:i18n"
import { getEntry, render } from "astro:content"
import { MonitorIcon, SmartphoneIcon } from "lucide-react"

import { CursorOverlay } from "@/components/docs/CursorOverlay"
import { HeartButton } from "@/components/docs/HeartButton"
import { VariantSelector } from "@/components/docs/VariantSelector"
import { Badge } from "@/components/ui/badge"
import Docs from "@/layouts/Docs.astro"
import { getButtonVariant, listButtonSlugs } from "@/lib/button-components"

export function getStaticPaths() {
  return listButtonSlugs().map((slug) => ({ params: { variant: slug } }))
}

const { variant: slug } = Astro.params as { variant: string }

const variant = getButtonVariant(slug, "ko")
if (!variant) return Astro.redirect("/")

const pageEntry = await getEntry("pages", "button.ko")
if (!pageEntry) throw new Error("Missing pages/button.ko.mdx")
const { Content: PageBody, headings } = await render(pageEntry)

const toc = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({ id: h.slug, text: h.text, depth: h.depth as 2 | 3 }))
---

<Docs title={`Button — ${slug}`} description={variant.tagline} toc={toc}>
  <div class="flex min-w-0 flex-1 flex-col">
    <div class="h-(--top-spacing) shrink-0"></div>
    <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-8 px-4 py-6 md:px-0 lg:py-8">
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between gap-2">
          <VariantSelector
            currentSlug={slug}
            items={listButtonSlugs().map((s) => ({
              slug: s,
              href: getRelativeLocaleUrl("ko", `docs/components/button/${s}`),
            }))}
            client:idle
          />
          <HeartButton slug={slug} client:idle />
        </div>
        <div class="flex flex-col gap-2">
          <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">Button</h1>
          {variant.support === "desktop" && (
            <Badge variant="outline">
              <MonitorIcon />
              Desktop only
            </Badge>
          )}
          {variant.support === "mobile" && (
            <Badge variant="outline">
              <SmartphoneIcon />
              Mobile only
            </Badge>
          )}
          <p class="text-[1.05rem] text-muted-foreground sm:text-base">{variant.tagline}</p>
        </div>
      </div>

      <article class="prose-section">
        <PageBody slug={slug} description={variant.description} />
      </article>
    </div>
  </div>
  <CursorOverlay channel={`cursors:button:${slug}`} client:idle />
</Docs>
