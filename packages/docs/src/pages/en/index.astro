---
import Site from "@/layouts/Site.astro"

const title = "Beautifully designed. Unforgettably interactive."
const description =
  "Every website looks the same. Stand out with components your users will actually remember."
---

<Site title={title} description={description}>
  <div class="flex flex-1 flex-col justify-center">
    <section class="border-grid">
      <div class="container-wrapper">
        <div class="container flex flex-col items-center justify-center gap-2 px-6 py-8 text-center md:py-16 lg:py-20 xl:gap-4">
          <h1
            class="leading-tighter max-w-3xl text-3xl font-semibold tracking-tight text-balance text-primary lg:leading-[1.1] lg:font-semibold xl:text-5xl xl:tracking-tighter"
          >
            {title}
          </h1>
          <p class="max-w-4xl text-base text-balance text-foreground sm:text-lg">{description}</p>
          <div class="flex w-full items-center justify-center gap-2 pt-2 **:data-[slot=button]:shadow-none">
            <a
              href="/en/docs"
              class="inline-flex h-[31px] items-center justify-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground hover:bg-primary/90"
            >
              Get Started
            </a>
            <a
              href="/en/docs/components/button"
              class="inline-flex h-[31px] items-center justify-center rounded-lg px-4 text-sm font-medium hover:bg-accent hover:text-accent-foreground"
            >
              View Components
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Site>
