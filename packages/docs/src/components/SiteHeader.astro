---
import { GitHubLink } from "@/components/GitHubLink"
import { HomeLink } from "@/components/HomeLink"
import { InstagramLink } from "@/components/InstagramLink"
import LocaleSwitcher from "@/components/LocaleSwitcher.astro"
import { MobileNav } from "@/components/MobileNav"
import { getLocale, tFor } from "@/i18n/locale"
import { listVariantsForComponent } from "@/lib/variants"

const locale = getLocale(Astro)
const s = tFor(Astro)
const basePath = locale === "en" ? "/en" : ""
const buttonVariants = await listVariantsForComponent("button", locale)
const buttonHref = `${basePath}/docs/components/button/${buttonVariants[0]?.slug ?? "escape"}`
const navStrings = {
  menu: s.menu,
  home: s.home,
  sections: s.sections,
  components: s.components,
  introduction: s.introduction,
  installation: s.installation,
  toggleMenu: s.toggleMenu,
}

let stars = ""
try {
  const res = await fetch("https://api.github.com/repos/yeolyi/chadcn-ui")
  const json = (await res.json()) as { stargazers_count?: number }
  const c = json.stargazers_count ?? 0
  stars = c >= 1000 ? `${Math.round(c / 1000)}k` : c.toLocaleString()
} catch {}
---

<header class="sticky top-0 z-50 w-full bg-background">
  <div class="container-wrapper px-6 3xl:fixed:px-0">
    <div class="flex h-(--header-height) items-center 3xl:fixed:container">
      <MobileNav client:load basePath={basePath} strings={navStrings} buttonHref={buttonHref} />
      <HomeLink href={basePath || "/"} />
      <div class="ml-auto flex items-center gap-2">
        <LocaleSwitcher />
        <span class="h-4 w-px bg-border" data-slot="separator"></span>
        <InstagramLink followers="35k" />
        <GitHubLink stars={stars} />
      </div>
    </div>
  </div>
</header>
