---
import { getRelativeLocaleUrl } from "astro:i18n"

import { t } from "@/i18n/strings"
import { listVariantsForComponent } from "@/lib/variants"

const locale = Astro.currentLocale ?? "ko"
const s = t(locale)

const buttonVariants = await listVariantsForComponent("button", locale)
const buttonSlug = buttonVariants[0]?.slug ?? "escape"

const sections = [
  { name: s.introduction, href: getRelativeLocaleUrl(locale, "docs") },
  { name: s.installation, href: getRelativeLocaleUrl(locale, "docs/installation") },
]

const components = [
  { name: "Button", href: getRelativeLocaleUrl(locale, `docs/components/button/${buttonSlug}`) },
]

const pathname = new URL(Astro.request.url).pathname
const norm = (p: string) => (p.length > 1 && p.endsWith("/") ? p.slice(0, -1) : p)
const current = norm(pathname)

const linkClass = (href: string) =>
  `relative flex h-[30px] items-center w-fit overflow-visible rounded-md border border-transparent px-2 text-[0.8rem] font-medium ${
    current === norm(href) ? "border-accent bg-accent text-foreground" : "text-foreground/70 hover:text-foreground"
  }`
---

<aside
  class="sticky top-[calc(var(--header-height)+0.6rem)] z-30 hidden h-[calc(100svh-10rem)] overscroll-none lg:flex flex-col bg-transparent w-56"
>
  <div class="h-9"></div>
  <div class="absolute top-12 right-2 bottom-0 hidden h-full w-px bg-linear-to-b from-transparent via-border to-transparent lg:flex"></div>
  <div class="no-scrollbar overflow-x-hidden overflow-y-auto px-2">
    <div class="pt-6">
      <div class="px-2 py-1 text-xs font-medium text-muted-foreground">{s.sections}</div>
      <nav class="flex flex-col gap-0.5 mt-1">
        {sections.map(({ name, href }) => (
          <a href={href} class={linkClass(href)}>{name}</a>
        ))}
      </nav>
    </div>
    <div class="mt-4">
      <div class="px-2 py-1 text-xs font-medium text-muted-foreground">{s.components}</div>
      <nav class="flex flex-col gap-0.5 mt-1">
        {components.map(({ name, href }) => (
          <a href={href} class={linkClass(href)}>{name}</a>
        ))}
      </nav>
    </div>
  </div>
</aside>
