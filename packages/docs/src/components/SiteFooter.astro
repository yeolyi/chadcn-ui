---
import { t } from "@/i18n/strings"
import { siteConfig } from "@/lib/config"

const locale = Astro.currentLocale ?? "ko"
const s = t(locale)
---

<footer class="dark:bg-transparent 3xl:fixed:bg-transparent">
  <div class="container-wrapper px-4 xl:px-6">
    <div class="flex h-(--footer-height) items-center justify-between">
      <div class="w-full px-1 text-center text-xs leading-loose text-muted-foreground sm:text-sm">
        {locale === "en" ? (
          <>
            Built on
            <a href="https://github.com/shadcn-ui/ui" target="_blank" rel="noreferrer" class="font-medium underline underline-offset-4">shadcn/ui</a>{s.builtOn}
            <a href={siteConfig.links.github} target="_blank" rel="noreferrer" class="font-medium underline underline-offset-4">GitHub</a>{s.sourceOnGithub}
          </>
        ) : (
          <>
            <a href="https://github.com/shadcn-ui/ui" target="_blank" rel="noreferrer" class="font-medium underline underline-offset-4">shadcn/ui</a>{s.builtOn}
            <a href={siteConfig.links.github} target="_blank" rel="noreferrer" class="font-medium underline underline-offset-4">GitHub</a>{s.sourceOnGithub}
          </>
        )}
      </div>
    </div>
  </div>
</footer>
