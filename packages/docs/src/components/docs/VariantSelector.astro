---
import { getRelativeLocaleUrl } from "astro:i18n"

import { getLocale } from "@/i18n/locale"
import { listButtonSlugs } from "@/lib/button-components"

interface Props {
  currentSlug: string
}

const { currentSlug } = Astro.props
const locale = getLocale(Astro)
const slugs = listButtonSlugs()
---

<div class="relative" data-variant-selector>
  <button
    type="button"
    class="inline-flex h-8 items-center justify-center gap-1.5 rounded-md border bg-background px-3 text-sm font-medium hover:bg-accent hover:text-accent-foreground"
    data-variant-trigger
    aria-haspopup="true"
    aria-expanded="false"
  >
    <span>{currentSlug}</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6" />
    </svg>
  </button>
  <ul
    class="absolute right-0 top-full z-30 mt-1 hidden min-w-[12rem] rounded-md border bg-popover p-1 text-popover-foreground shadow-md"
    data-variant-menu
    role="menu"
  >
    {
      slugs.map((slug) => (
        <li>
          <a
            href={getRelativeLocaleUrl(locale, `docs/components/button/${slug}`)}
            class={`flex items-center rounded-sm px-2 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground ${slug === currentSlug ? "bg-accent text-accent-foreground" : ""}`}
            role="menuitem"
          >
            <span>{slug}</span>
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-variant-selector]").forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>("[data-variant-trigger]")
    const menu = root.querySelector<HTMLUListElement>("[data-variant-menu]")
    if (!trigger || !menu) return
    const close = () => {
      menu.classList.add("hidden")
      trigger.setAttribute("aria-expanded", "false")
    }
    trigger.addEventListener("click", (e) => {
      e.stopPropagation()
      const isOpen = !menu.classList.contains("hidden")
      if (isOpen) close()
      else {
        menu.classList.remove("hidden")
        trigger.setAttribute("aria-expanded", "true")
      }
    })
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) close()
    })
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close()
    })
  })
</script>
