---
import { codeToHtml } from "shiki"

interface Props {
  code: string
  lang: string
  title?: string
}

const { code, lang, title } = Astro.props

// Dual-theme. Light is the inline default; dark colors live in CSS vars
// (--shiki-dark / --shiki-dark-bg) and globals.css swaps them in via
// prefers-color-scheme media query.
const html = await codeToHtml(code, {
  lang,
  themes: { light: "github-light", dark: "github-dark" },
  defaultColor: "light",
})
---

<figure class="not-prose relative my-6 overflow-hidden rounded-xl border bg-code text-code-foreground">
  {
    title && (
      <figcaption class="border-b border-border/50 px-4 py-2.5 font-mono text-sm text-code-foreground">
        {title}
      </figcaption>
    )
  }
  <div class="relative">
    <div class="overflow-x-auto px-4 py-3 text-sm" set:html={html} />
    <button
      type="button"
      data-copy
      data-code={code}
      class="absolute top-2 right-2 inline-flex size-6 items-center justify-center rounded-md text-foreground/70 hover:bg-accent hover:text-foreground"
      aria-label="Copy"
    >
      <svg
        data-icon="clipboard"
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="8" height="4" x="8" y="2" rx="1" ry="1" />
        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
      </svg>
      <svg
        data-icon="check"
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="20 6 9 17 4 12" />
      </svg>
    </button>
  </div>
</figure>
