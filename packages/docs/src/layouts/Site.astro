---
import "@/styles/globals.css"

import Analytics from "@vercel/analytics/astro"
import { Toaster } from "sonner"

import SiteFooter from "@/components/chrome/SiteFooter.astro"
import SiteHeader from "@/components/chrome/SiteHeader.astro"
import { getLocale, tFor } from "@/i18n/locale"
import { META_THEME_COLORS, siteConfig } from "@/lib/config"

interface Props {
  title?: string
  description?: string
}

const locale = getLocale(Astro)
const s = tFor(Astro)
const { title, description = s.siteDescription } = Astro.props
const fullTitle = title ? `${title} - ${siteConfig.name}` : siteConfig.name
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content={META_THEME_COLORS.light} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content={META_THEME_COLORS.dark} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={siteConfig.ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteConfig.ogImage} />
    <title>{fullTitle}</title>

    <link
      rel="preload"
      href="/fonts/silkscreen-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/silkscreen-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

  </head>
  <body
    class="group/body overscroll-none bg-background text-foreground antialiased [--footer-height:calc(var(--spacing)*14)] [--header-height:calc(var(--spacing)*14)] xl:[--footer-height:calc(var(--spacing)*24)]"
  >
    <div data-slot="layout" class="relative z-10 flex min-h-svh flex-col">
      <SiteHeader />
      <main class="flex flex-1 flex-col"><slot /></main>
      <SiteFooter />
    </div>
    <Analytics />
    <Toaster client:load richColors theme="system" position="bottom-right" />
    <script>
      // iOS Safari quirk: Radix DropdownMenu/Select use onPointerDown to open,
      // which is silently dropped on the first interaction with certain DOM
      // shapes (asChild/Slot). A no-op pointerdown listener on body warms up
      // the pointer event system so the first tap registers.
      // Ref: github.com/radix-ui/primitives/issues/2580, facebook/react#29890
      document.body.addEventListener("pointerdown", () => {}, { passive: true })
    </script>
    <script>
      // CodeBlock copy buttons: write to clipboard, swap to check icon for ~2s.
      document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement | null)?.closest<HTMLButtonElement>(
          "button[data-copy]",
        )
        if (!btn) return
        navigator.clipboard.writeText(btn.dataset.code ?? "")
        btn.dataset.copied = "true"
        setTimeout(() => btn.removeAttribute("data-copied"), 2000)
      })
    </script>
  </body>
</html>
