---
import { Code } from "astro-expressive-code/components"

import { InstallTabs } from "@/components/InstallTabs"
import { t } from "@/i18n/strings"
import Docs from "@/layouts/Docs.astro"

const locale = Astro.currentLocale ?? "ko"
const s = t(locale)

const usage = `import "@chadcn/ui/styles.css"

import { Button } from "@chadcn/ui"`

const toc = [
  { id: "install", text: s.installLabel, depth: 2 as const },
  { id: "usage", text: s.usageLabel, depth: 2 as const },
]
---

<Docs title={s.installationTitle} description={s.installationDescription} toc={toc}>
  <div class="flex min-w-0 flex-1 flex-col">
    <div class="h-(--top-spacing) shrink-0"></div>
    <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-8 px-4 py-6 text-foreground md:px-0 lg:py-8">
      <div class="flex flex-col gap-2">
        <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight">{s.installationTitle}</h1>
        <p class="text-[1.05rem] text-muted-foreground sm:text-base">{s.installationDescription}</p>
      </div>

      <section class="space-y-4">
        <h2 id="install" class="scroll-m-24 border-b pb-2 text-2xl font-semibold tracking-tight">
          {s.installLabel}
        </h2>
        <InstallTabs
          client:load
          pkg="@chadcn/ui"
          comingSoon
          comingSoonLabel={s.comingSoon}
          comingSoonDescription={s.comingSoonDescription}
          copySuccessMessage={s.copySuccess}
        />
      </section>

      <section class="space-y-4">
        <h2 id="usage" class="scroll-m-24 border-b pb-2 text-2xl font-semibold tracking-tight">
          {s.usageLabel}
        </h2>
        <p class="text-[0.95rem] leading-7 text-muted-foreground">{s.usageHelp}</p>
        <Code code={usage} lang="tsx" />
      </section>
    </div>
  </div>
</Docs>
